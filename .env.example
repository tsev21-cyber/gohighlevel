# ─── Anthropic Claude (lead qualification engine) ────────────────────────────
# Get a key at https://console.anthropic.com  → copy this file to ".env"
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model used by the bot. Haiku 4.5 = fast + cheap, ideal for a per-message
# qualification bot in production. Swap to claude-opus-4-8 for max quality.
CLAUDE_MODEL=claude-haiku-4-5

# ─── GoHighLevel (CRM) ───────────────────────────────────────────────────────
# Leave these blank to run in MOCK mode (no real CRM needed — the demo ships a
# built-in mock GHL that mirrors the real /contacts API shape).
# Fill them in to push qualified leads to a real GHL sub-account.
GHL_API_KEY=
GHL_LOCATION_ID=

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000
